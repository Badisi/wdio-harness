{
    "name": "@badisi/wdio-harness",
    "version": "4.4.0",
    "description": "WebdriverIO support for Angular component test harnesses.",
    "homepage": "https://github.com/Badisi/wdio-harness",
    "license": "MIT",
    "author": {
        "name": "Badisi"
    },
    "type": "module",
    "main": "./index.mjs",
    "module": "./index.mjs",
    "types": "./index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./index.d.mts",
                "default": "./index.mjs"
            }
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Badisi/wdio-harness.git"
    },
    "keywords": [
        "angular",
        "cdk",
        "components",
        "test",
        "testing",
        "harness",
        "harnesses",
        "test-harnesses",
        "wdio",
        "webdriver",
        "webdriverio"
    ],
    "scripts": {
        "build": "tsc --noEmit && tsdown",
        "release": "npm publish ../../dist --workspaces=false --access=public"
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": "^16.14.0 || >=18.10.0"
    },
    "peerDependencies": {
        "@angular/cdk": ">= 13 < 22",
        "@wdio/globals": ">= 9 < 10",
        "@wdio/logger": ">= 9 < 10",
        "webdriverio": ">= 9 < 10"
    },
    "devDependencies": {
        "@angular/cdk": "^22.0.4",
        "@wdio/globals": "9.29.1",
        "@wdio/logger": "9.29.1",
        "webdriverio": "9.29.1"
    }
}
